{
  "name": "appium-agent-inspector",
  "version": "0.1.0",
  "description": "Persistent Appium daemon server with CLI client, built on WebdriverIO",
  "type": "module",
  "bin": {
    "appium-agent": "./dist/cli/index.js",
    "appium-daemon": "./dist/daemon/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev:daemon": "tsx watch src/daemon/index.ts",
    "dev:cli": "tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/sensible": "^6.0.4",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "nanoid": "^5.1.9",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "webdriverio": "^9.27.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "appium": "^3.3.0",
    "appium-xcuitest-driver": "^11.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
